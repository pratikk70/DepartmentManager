{
  "compilerOptions": {
    "module": "Node16",
    "esModuleInterop": true,
    "target": "es6",
    "moduleResolution": "node16",
    "sourceMap": true,
    "outDir": "dist",
    "rootDir": "./src",
    "typeRoots": ["./src/@types", "./node_modules/@types"],
    "types": ["node"],
    "lib": ["es2015", "dom"],
    "strict": false,
    "skipLibCheck": true
  },
  "include": ["src/**/*"],
  "exclude": ["node_modules"]
}